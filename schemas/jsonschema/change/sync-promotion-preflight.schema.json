{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.grafana-util.local/change/sync-promotion-preflight.schema.json",
  "title": "Change promotion-preflight JSON schema",
  "type": "object",
  "required": [
    "kind",
    "schemaVersion",
    "toolVersion",
    "summary",
    "bundlePreflight",
    "mappingSummary",
    "checkSummary",
    "handoffSummary",
    "continuationSummary",
    "checks",
    "resolvedChecks",
    "blockingChecks"
  ],
  "additionalProperties": false,
  "properties": {
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "kind": {},
          "identity": {},
          "status": {}
        },
        "required": [
          "kind",
          "identity",
          "status"
        ],
        "additionalProperties": false
      }
    },
    "resolvedChecks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "kind": {},
          "identity": {},
          "status": {}
        },
        "required": [
          "kind",
          "identity",
          "status"
        ],
        "additionalProperties": false
      }
    },
    "blockingChecks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "kind": {},
          "identity": {},
          "status": {}
        },
        "required": [
          "kind",
          "identity",
          "status"
        ],
        "additionalProperties": false
      }
    }
  }
}
