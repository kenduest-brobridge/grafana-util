{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.grafana-util.local/change/alert-sync-plan.schema.json",
  "title": "Change assess-alerts JSON schema",
  "type": "object",
  "required": [
    "kind",
    "schemaVersion",
    "toolVersion",
    "summary",
    "alerts"
  ],
  "additionalProperties": false,
  "properties": {
    "summary": {
      "type": "object",
      "properties": {
        "alertCount": {},
        "blockingCount": {}
      },
      "required": [
        "alertCount",
        "blockingCount"
      ],
      "additionalProperties": false
    },
    "alerts": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "kind": {},
          "identity": {},
          "status": {}
        },
        "required": [
          "kind",
          "identity",
          "status"
        ],
        "additionalProperties": false
      }
    }
  }
}
