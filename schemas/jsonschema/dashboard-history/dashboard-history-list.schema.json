{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.grafana-util.local/dashboard-history/dashboard-history-list.schema.json",
  "title": "Dashboard history list JSON schema",
  "type": "object",
  "required": [
    "kind",
    "schemaVersion",
    "toolVersion",
    "dashboardUid",
    "versionCount",
    "versions"
  ],
  "additionalProperties": false,
  "properties": {
    "versions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "version": {},
          "created": {},
          "createdBy": {},
          "message": {}
        },
        "required": [
          "version",
          "created",
          "createdBy",
          "message"
        ],
        "additionalProperties": false
      }
    }
  }
}
